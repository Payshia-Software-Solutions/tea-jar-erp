    LAST_DAY(DATE_ADD(CURDATE(), INTERVAL 1 MONTH))                     AS forecast_end_date,
    SUM(`grand_total`) AS forecast_revenue
FROM `invoices`
WHERE `issue_date` >= DATE_FORMAT(DATE_ADD(LAST_DAY(CURDATE()), INTERVAL 1 DAY), '%Y-%m-01')
  AND `issue_date` <= LAST_DAY(DATE_ADD(CURDATE(), INTERVAL 1 MONTH))
  AND `status` <> 'cancelled';
