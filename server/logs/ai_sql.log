SQL: SELECT 
    p.id AS part_id,
    p.part_name,
    SUM(ii.quantity)        AS total_quantity_sold,
    SUM(ii.line_total)      AS total_sales_amount
FROM `invoice_items` AS ii
JOIN `parts` AS p
      ON ii.item_id = p.id
      AND ii.item_type = 'part'          -- ensure we are counting parts only
JOIN `invoices` AS i
      ON ii.invoice_id = i.id
      AND i.status = 'paid'              -- optional: consider only paid invoices
GROUP BY p.id, p.part_name
ORDER BY total_quantity_sold DESC
LIMIT 10;
