<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ DARK THEME — Deep Navy + Jewel Tones ═══ -->

    <!-- Page Backgrounds -->
    <SolidColorBrush x:Key="BgPage"         Color="#060B18"/>
    <SolidColorBrush x:Key="BgPanel"        Color="#0A1020"/>
    <SolidColorBrush x:Key="BgCard"         Color="#0F172A"/>
    <SolidColorBrush x:Key="BgCardElevated" Color="#141E30"/>
    <SolidColorBrush x:Key="BgInput"        Color="#1E2A42"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#7B8FAD"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#445570"/>
    <SolidColorBrush x:Key="TextInverted"  Color="#060B18"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderPrimary" Color="#1A2540"/>
    <SolidColorBrush x:Key="BorderLight"   Color="#253050"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentPrimary"   Color="#6366F1"/>
    <SolidColorBrush x:Key="AccentSecondary" Color="#38BDF8"/>
    <SolidColorBrush x:Key="AccentSuccess"   Color="#10B981"/>
    <SolidColorBrush x:Key="AccentWarning"   Color="#FBBF24"/>
    <SolidColorBrush x:Key="AccentDanger"    Color="#EF4444"/>

    <!-- Icon Pill Backgrounds — Rich jewel tones, clearly visible on dark navy cards -->
    <SolidColorBrush x:Key="IconBgIndigo"  Color="#2E2D8F"/>
    <SolidColorBrush x:Key="IconBgPurple"  Color="#4A1D8A"/>
    <SolidColorBrush x:Key="IconBgBlue"    Color="#1A4080"/>
    <SolidColorBrush x:Key="IconBgGreen"   Color="#065F46"/>
    <SolidColorBrush x:Key="IconBgAmber"   Color="#78350F"/>
    <SolidColorBrush x:Key="IconBgRed"     Color="#7F1D1D"/>
    <SolidColorBrush x:Key="IconBgCyan"    Color="#164E63"/>

    <!-- Icon Foreground — bright vivid tones, high contrast on jewel backgrounds -->
    <SolidColorBrush x:Key="IconFgIndigo"  Color="#A5B4FC"/>
    <SolidColorBrush x:Key="IconFgPurple"  Color="#D8B4FE"/>
    <SolidColorBrush x:Key="IconFgBlue"    Color="#93C5FD"/>
    <SolidColorBrush x:Key="IconFgGreen"   Color="#6EE7B7"/>
    <SolidColorBrush x:Key="IconFgAmber"   Color="#FDE68A"/>
    <SolidColorBrush x:Key="IconFgRed"     Color="#FCA5A5"/>
    <SolidColorBrush x:Key="IconFgCyan"    Color="#A5F3FC"/>

    <!-- Shadow -->
    <Color x:Key="ShadowColor">#000000</Color>
</ResourceDictionary>
