<Window x:Class="DesktopPOS.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading..." Height="420" Width="640"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent"
        Icon="Assets/app-icon.png">
    
    <Border Background="#0F172A" CornerRadius="16" BorderBrush="#1E293B" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.5" ShadowDepth="10"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Image Source="Assets/app-icon.png" Width="140" Height="140" Margin="0,0,0,24">
                    <Image.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.3" ShadowDepth="4"/>
                    </Image.Effect>
                </Image>
                
                <TextBlock Text="Bizzflow POS" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Next Generation Auto Repair Point of Sale" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="40,0,40,40">
                <Grid Margin="0,0,0,8">
                    <TextBlock x:Name="LoadingText" Text="Initializing system..." Foreground="#38BDF8" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="LoadingPercent" Text="0%" Foreground="#94A3B8" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="LoadingBar" Height="6" BorderThickness="0" 
                             Background="#1E293B" Foreground="#38BDF8"
                             Minimum="0" Maximum="100" Value="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
