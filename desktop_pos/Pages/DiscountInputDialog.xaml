<Window x:Class="DesktopPOS.Pages.DiscountInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Line Discount" Height="220" Width="320"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Border Background="{DynamicResource BgCardElevated}" CornerRadius="16" Padding="28">
        <StackPanel>
            <TextBlock Text="LINE DISCOUNT" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource BgCard}" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                <TextBox x:Name="AmountBox" Background="Transparent" Foreground="{DynamicResource AccentWarning}"
                         BorderThickness="0" FontSize="22" FontWeight="Bold" CaretBrush="{DynamicResource AccentWarning}" Text="0">
                    <TextBox.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Height="40" Margin="0,0,6,0"
                        Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                        FontSize="13" Click="Cancel_Click" IsCancel="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="1" Content="Apply" Height="40" Margin="6,0,0,0"
                        Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="Bold" Click="Apply_Click" IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>







