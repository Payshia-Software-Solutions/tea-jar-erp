<Window x:Class="DesktopPOS.Pages.BillDiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bill Discount" Height="500" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    
    <Grid Background="Transparent">
        <Border Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="60" ShadowDepth="10"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="APPLY BILL DISCOUNT" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="4,0,0,10"/>

                <!-- Mode Selector Toggle -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border x:Name="PercentModeBtn" Grid.Column="0" Background="{DynamicResource BgInput}" CornerRadius="10,0,0,10" Padding="12,10" Cursor="Hand" PreviewMouseLeftButtonDown="PercentMode_Click">
                        <TextBlock x:Name="PercentModeText" Text="Percentage (%)" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13"/>
                    </Border>
                    <Border x:Name="ValueModeBtn" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="0,10,10,0" Padding="12,10" Cursor="Hand" PreviewMouseLeftButtonDown="ValueMode_Click">
                        <TextBlock x:Name="ValueModeText" Text="Fixed Amount (LKR)" Foreground="{DynamicResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="13"/>
                    </Border>
                </Grid>

                <!-- Display -->
                <Border Grid.Row="2" Background="{DynamicResource BgCard}" CornerRadius="10" Padding="16,14" Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock x:Name="SuffixLabel" Text="%" DockPanel.Dock="Right" Foreground="{DynamicResource AccentWarning}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock x:Name="AmountDisplay" Text="0" Foreground="{DynamicResource TextPrimary}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Numpad -->
                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1 -->
                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="1">
                        <TextBlock Text="1" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="2">
                        <TextBlock Text="2" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="3">
                        <TextBlock Text="3" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>

                    <!-- Row 2 -->
                    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="4">
                        <TextBlock Text="4" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="5">
                        <TextBlock Text="5" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="6">
                        <TextBlock Text="6" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>

                    <!-- Row 3 -->
                    <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="7">
                        <TextBlock Text="7" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="8">
                        <TextBlock Text="8" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="9">
                        <TextBlock Text="9" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>

                    <!-- Row 4 -->
                    <Border Grid.Row="3" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag=".">
                        <TextBlock Text="." Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="0">
                        <TextBlock Text="0" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="2" Background="{DynamicResource IconBgRed}" CornerRadius="10" Margin="3" Cursor="Hand" PreviewMouseLeftButtonDown="Del_Click">
                        <TextBlock Text="DEL" Foreground="{DynamicResource AccentDanger}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                </Grid>

                <!-- Actions -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Cancel" Height="44" Margin="0,0,6,0" IsCancel="True"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="13" Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Content="Apply" Height="44" Margin="6,0,0,0" IsDefault="True"
                            Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0"
                            FontSize="13" FontWeight="Bold" Click="Apply_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
