<Window x:Class="DesktopPOS.Pages.OrderTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Order" 
        Height="550" Width="600"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="500" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="36,32">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="60" ShadowDepth="10"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,36">
                    <Button DockPanel.Dock="Right" Content="✕" Width="32" Height="32"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="14" Click="Close_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="New Order" Foreground="{DynamicResource TextPrimary}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="Select service mode" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Dine In [1] -->
                <Border x:Name="DineInOption" Background="{DynamicResource BgCard}" CornerRadius="14" Margin="0,0,0,12"
                        Cursor="Hand" MouseLeftButtonUp="DineIn_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource IconBgIndigo}">
                            <TextBlock Text="▣" Foreground="{DynamicResource IconFgIndigo}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="Dine In" Foreground="{DynamicResource TextPrimary}" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="Table service" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{DynamicResource BgInput}" CornerRadius="6" VerticalAlignment="Center" Padding="8,4" Margin="0,0,16,0" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="1" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="→" Foreground="{DynamicResource AccentSecondary}" FontSize="22" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Take Away [2] -->
                <Border x:Name="TakeAwayOption" Background="{DynamicResource BgCard}" CornerRadius="14" Margin="0,0,0,12"
                        Cursor="Hand" MouseLeftButtonUp="TakeAway_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource IconBgGreen}">
                            <TextBlock Text="◈" Foreground="{DynamicResource IconFgGreen}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="Take Away" Foreground="{DynamicResource TextPrimary}" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="Collection" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{DynamicResource BgInput}" CornerRadius="6" VerticalAlignment="Center" Padding="8,4" Margin="0,0,16,0" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="2" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="→" Foreground="{DynamicResource AccentSecondary}" FontSize="22" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Retail [3] -->
                <Border x:Name="RetailOption" Background="{DynamicResource BgCard}" CornerRadius="14" Margin="0,0,0,0"
                        Cursor="Hand" MouseLeftButtonUp="Retail_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource IconBgAmber}">
                            <TextBlock Text="⌂" Foreground="{DynamicResource IconFgAmber}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="Retail" Foreground="{DynamicResource TextPrimary}" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="Standard sale" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{DynamicResource BgInput}" CornerRadius="6" VerticalAlignment="Center" Padding="8,4" Margin="0,0,16,0" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="3" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="→" Foreground="{DynamicResource AccentSecondary}" FontSize="22" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
