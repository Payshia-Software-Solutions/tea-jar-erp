<Window x:Class="DesktopPOS.Pages.LocationSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Default Branch" 
        Height="550" Width="600"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="500" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="36,32">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="60" ShadowDepth="10"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,36">
                    <Button DockPanel.Dock="Right" Content="✕" Width="32" Height="32"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="14" Click="Close_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="Select Branch" Foreground="{DynamicResource TextPrimary}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="Please select your operating location" Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- List of branches -->
                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LocationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgCard}" CornerRadius="12" Margin="0,0,0,10"
                                        Padding="20,16" Cursor="Hand" MouseLeftButtonUp="Location_Click" Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="False">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <TextBlock Text="🏪" Foreground="{DynamicResource AccentSecondary}" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding name}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="→" Foreground="{DynamicResource AccentSecondary}" FontSize="20" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
