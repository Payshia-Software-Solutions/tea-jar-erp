<Page x:Class="DesktopPOS.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:DesktopPOS.Controls"
      Title="Settings" Background="{DynamicResource BgPage}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:TopNavBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24,32,40">

                <!-- Page Title Row -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="← Back" Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                            FontSize="14" FontWeight="SemiBold" BorderThickness="0"
                            Margin="0,0,16,0" Cursor="Hand" Click="Back_Click"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Settings" Foreground="{DynamicResource TextPrimary}"
                               FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- HARDWARE & PRINTING — two cards side by side       -->
                <!-- ══════════════════════════════════════════════════ -->
                <TextBlock Text="HARDWARE &amp; PRINTING" Foreground="{DynamicResource TextMuted}"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Receipt Printer Card -->
                    <Border Grid.Column="0" Background="{DynamicResource BgCardElevated}" CornerRadius="14"
                            Padding="24" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.07" BlurRadius="20" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Icon + Title -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="44" Height="44" CornerRadius="11"
                                        Background="{DynamicResource IconBgIndigo}" Margin="0,0,14,0">
                                    <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Receipt Printer" Foreground="{DynamicResource TextPrimary}"
                                               FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Default printer for customer checkout receipts."
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Separator -->
                            <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,0,0,14"/>

                            <!-- Dropdown + Test -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                                        CornerRadius="8" Background="{DynamicResource BgInput}" Padding="2">
                                    <ComboBox x:Name="ReceiptPrinterComboBox" Height="40" FontSize="14"
                                              Padding="12,10" Background="Transparent" BorderThickness="0"/>
                                </Border>
                                <Button Grid.Column="2" Content="TEST" Width="72" Height="44"
                                        Background="{DynamicResource AccentSecondary}"
                                        Foreground="White" FontWeight="Bold" FontSize="13"
                                        BorderThickness="0" Cursor="Hand" Click="TestReceiptPrinter_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- KOT Printer Card -->
                    <Border Grid.Column="2" Background="{DynamicResource BgCardElevated}" CornerRadius="14"
                            Padding="24" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.07" BlurRadius="20" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Icon + Title -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="44" Height="44" CornerRadius="11"
                                        Background="{DynamicResource IconBgAmber}" Margin="0,0,14,0">
                                    <TextBlock Text="🍳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Kitchen Order Ticket (KOT) Printer" Foreground="{DynamicResource TextPrimary}"
                                               FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Printer for dispatching Order Tickets to the kitchen."
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Separator -->
                            <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,0,0,14"/>

                            <!-- Dropdown + Test -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                                        CornerRadius="8" Background="{DynamicResource BgInput}" Padding="2">
                                    <ComboBox x:Name="KotPrinterComboBox" Height="40" FontSize="14"
                                              Padding="12,10" Background="Transparent" BorderThickness="0"/>
                                </Border>
                                <Button Grid.Column="2" Content="TEST" Width="72" Height="44"
                                        Background="{DynamicResource AccentSecondary}"
                                        Foreground="White" FontWeight="Bold" FontSize="13"
                                        BorderThickness="0" Cursor="Hand" Click="TestKotPrinter_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SERVER URL (Admin only)                            -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border x:Name="ServerUrlCard" Visibility="Collapsed" Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock Text="SERVER CONFIGURATION" Foreground="{DynamicResource TextMuted}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BgCardElevated}" CornerRadius="14"
                                Padding="24" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.07" BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="11"
                                        Background="{DynamicResource IconBgIndigo}"
                                        VerticalAlignment="Top" Margin="0,0,18,0">
                                    <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Server Connection Settings" Foreground="{DynamicResource TextPrimary}"
                                               FontSize="16" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Modify the main SaaS API Server URL endpoint. Visible only to Administrator users."
                                               Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                               Margin="0,0,0,14" TextWrapping="Wrap"/>
                                    <Border BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                                            CornerRadius="8" Background="{DynamicResource BgInput}" Padding="2">
                                        <TextBox x:Name="ServerUrlTextBox" Height="42" FontSize="14"
                                                 Padding="12,10" Background="Transparent"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 BorderThickness="0"
                                                 CaretBrush="{DynamicResource TextPrimary}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- DEFAULT CUSTOMER -->
                <!-- ══════════════════════════════════════════════════ -->
                <TextBlock Text="GENERAL SETTINGS" Foreground="{DynamicResource TextMuted}"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                <Border Background="{DynamicResource BgCardElevated}" CornerRadius="14" Margin="0,0,0,28"
                        Padding="24" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.07" BlurRadius="20" ShadowDepth="4"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="11"
                                Background="{DynamicResource IconBgIndigo}"
                                VerticalAlignment="Top" Margin="0,0,18,0">
                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Default Walk-in Customer" Foreground="{DynamicResource TextPrimary}"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock Text="Select the default customer mapped to POS sales when no explicit customer is chosen."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                       Margin="0,0,0,14" TextWrapping="Wrap"/>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                                        CornerRadius="8" Background="{DynamicResource BgInput}" Padding="2" Margin="0,0,10,0">
                                    <TextBlock x:Name="DefaultCustomerText" Text="Select Customer..." 
                                               Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Border>
                                <Button Grid.Column="1" Content="SELECT" Width="90" Height="44"
                                        Background="{DynamicResource AccentPrimary}"
                                        Foreground="White" FontWeight="Bold" FontSize="13"
                                        BorderThickness="0" Cursor="Hand" Click="SelectDefaultCustomer_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,0,0,16"/>

                            <TextBlock Text="Appearance / Theme" Foreground="{DynamicResource TextPrimary}"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock Text="Choose the default visual theme for the POS interface."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                       Margin="0,0,0,10" TextWrapping="Wrap"/>
                            
                            <Border BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                                    CornerRadius="8" Background="{DynamicResource BgInput}" Padding="2" HorizontalAlignment="Left" Width="200">
                                <ComboBox x:Name="ThemeComboBox" Height="40" FontSize="14"
                                          Padding="12,10" Background="Transparent" BorderThickness="0">
                                    <ComboBoxItem Content="Dark Theme"/>
                                    <ComboBoxItem Content="Light Theme"/>
                                </ComboBox>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- LOCATION + SYSTEM — two cards side by side         -->
                <!-- ══════════════════════════════════════════════════ -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Location Info Card -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LOCATION &amp; TAXES" Foreground="{DynamicResource TextMuted}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BgCardElevated}" CornerRadius="14"
                                Padding="24" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.07" BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="11"
                                        Background="{DynamicResource IconBgEmerald}"
                                        VerticalAlignment="Top" Margin="0,0,18,0">
                                    <TextBlock Text="📍" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Location Information" Foreground="{DynamicResource TextPrimary}"
                                               FontSize="16" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Details and configuration for the currently active operating branch."
                                               Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                               Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Current Branch:"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" x:Name="BranchNameText" Text="Loading..."
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Active Taxes:"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                        <ItemsControl Grid.Column="1" x:Name="ActiveTaxesList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BgInput}" CornerRadius="6"
                                                            Padding="8,4" Margin="0,0,8,8"
                                                            HorizontalAlignment="Left" MinWidth="110">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding code}" Foreground="{DynamicResource TextPrimary}"
                                                                       FontWeight="Bold" FontSize="12" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding rate_percent, StringFormat='{} {0}%'}"
                                                                       Foreground="{DynamicResource AccentWarning}"
                                                                       FontSize="12" FontWeight="Bold" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding apply_on, StringFormat='({0})'}"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       FontSize="11" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- System Management Card -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SYSTEM MANAGEMENT" Foreground="{DynamicResource TextMuted}"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BgCardElevated}" CornerRadius="14"
                                Padding="24" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.07" BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="11"
                                        Background="{DynamicResource IconBgPurple}"
                                        VerticalAlignment="Top" Margin="0,0,18,0">
                                    <TextBlock Text="🧹" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="System Cache" Foreground="{DynamicResource TextPrimary}"
                                               FontSize="16" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Clear locally cached products, tables, and steward data to force a fresh sync from the server."
                                               Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                               Margin="0,0,0,20" TextWrapping="Wrap"/>
                                    <Button Content="CLEAR CACHES" Height="44"
                                            HorizontalAlignment="Left" Padding="24,0"
                                            Background="{DynamicResource AccentDanger}"
                                            Foreground="White" FontWeight="Bold" FontSize="13"
                                            BorderThickness="0" Cursor="Hand" Click="ClearCache_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Save Button -->
                <Button Content="SAVE CONFIGURATION" Height="48" Width="210"
                        HorizontalAlignment="Left" Margin="0,28,0,0"
                        Background="{DynamicResource AccentPrimary}"
                        Foreground="White" FontWeight="Bold" FontSize="14"
                        BorderThickness="0" Cursor="Hand" Click="SaveSettings_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
