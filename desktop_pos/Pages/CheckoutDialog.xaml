<Window x:Class="DesktopPOS.Pages.CheckoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POS Checkout" Height="680" Width="820"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="800" Height="640" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="32" BorderThickness="1" BorderBrush="{DynamicResource BorderPrimary}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="50" ShadowDepth="8"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: Payment Method & Details -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="POS CHECKOUT" Foreground="{DynamicResource TextPrimary}" FontSize="22" FontWeight="Black"/>
                            <TextBlock Text="Select payment mode and details" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="30" Height="30"
                                Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                                FontSize="12" Click="Cancel_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Total Due Display -->
                    <Border Grid.Row="1" Background="{DynamicResource BgPage}" CornerRadius="12" Padding="18,14" Margin="0,0,0,20" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                        <DockPanel>
                            <TextBlock Text="TOTAL DUE" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="GrandTotalDisplay" Text="LKR 0.00" Foreground="{DynamicResource AccentSuccess}"
                                       FontSize="24" FontWeight="Black" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Details Area -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-12,0" Padding="0,0,12,0">
                        <StackPanel>
                            <!-- Method Grid Selection -->
                            <TextBlock Text="PAYMENT METHOD" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" x:Name="CashBtn" Content="💵  Cash" Height="42" Click="PaymentMethodBtn_Click" Style="{DynamicResource MethodBtnStyle}"/>
                                <Button Grid.Row="0" Grid.Column="2" x:Name="CardBtn" Content="💳  Card" Height="42" Click="PaymentMethodBtn_Click" Style="{DynamicResource MethodBtnStyle}"/>
                                <Button Grid.Row="2" Grid.Column="0" x:Name="ChequeBtn" Content="📝  Cheque" Height="42" Click="PaymentMethodBtn_Click" Style="{DynamicResource MethodBtnStyle}"/>
                                <Button Grid.Row="2" Grid.Column="2" x:Name="TransferBtn" Content="🏦  Bank Transfer" Height="42" Click="PaymentMethodBtn_Click" Style="{DynamicResource MethodBtnStyle}"/>
                            </Grid>

                            <Button x:Name="CreditBtn" Content="📋  Credit Close — Invoice later" Height="42" Margin="0,0,0,18" Click="PaymentMethodBtn_Click"
                                    Background="Transparent" Foreground="{DynamicResource AccentDanger}" BorderThickness="1" BorderBrush="{DynamicResource AccentDanger}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Contextual Inputs -->
                            <!-- Tendered Panel -->
                            <StackPanel x:Name="TenderedPanel" Visibility="Visible">
                                <TextBlock Text="AMOUNT TENDERED" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Border Background="{DynamicResource BgInput}" CornerRadius="10" Padding="14,0" Margin="0,0,0,12" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                                    <DockPanel>
                                        <TextBlock Text="LKR" Foreground="{DynamicResource TextSecondary}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="TenderedBox" Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                                 BorderThickness="0" FontSize="20" FontWeight="Black" Padding="0,10"
                                                 CaretBrush="{DynamicResource TextPrimary}" TextChanged="TenderedBox_TextChanged" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <UniformGrid Columns="4" Margin="0,0,0,16">
                                    <Button Content="Exact" Margin="0,0,4,0" Height="32" Click="BumpAmount_Click" Style="{DynamicResource BumpBtnStyle}"/>
                                    <Button Content="+500" Margin="2,0,2,0" Height="32" Click="BumpAmount_Click" Style="{DynamicResource BumpBtnStyle}"/>
                                    <Button Content="+1000" Margin="2,0,2,0" Height="32" Click="BumpAmount_Click" Style="{DynamicResource BumpBtnStyle}"/>
                                    <Button Content="+5000" Margin="4,0,0,0" Height="32" Click="BumpAmount_Click" Style="{DynamicResource BumpBtnStyle}"/>
                                </UniformGrid>
                            </StackPanel>



                            <!-- Change Due info -->
                            <Border x:Name="ChangeBorder" Background="{DynamicResource IconBgGreen}" CornerRadius="10" Padding="18,12" Margin="0,0,0,14" BorderBrush="{DynamicResource IconFgGreen}" BorderThickness="1" Visibility="Collapsed">
                                <DockPanel>
                                    <TextBlock Text="Change Due" Foreground="{DynamicResource IconFgGreen}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ChangeText" Text="LKR 0.00" Foreground="{DynamicResource IconFgGreen}"
                                               FontSize="16" FontWeight="Black" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bottom Action -->
                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource AccentDanger}" FontSize="12" Margin="0,0,0,10"
                                   Visibility="Collapsed" TextWrapping="Wrap" FontWeight="Bold"/>

                        <Button x:Name="ConfirmButton" Content="Process &amp; Print Invoice (Enter / F9)" Height="48" Click="ConfirmPayment_Click"
                                Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#4F46E5" BlurRadius="16" Opacity="0.3" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- RIGHT COLUMN: Billing Customer & Quick Numpad -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Billing Customer Section -->
                    <TextBlock Grid.Row="0" Text="👤  BILLING CUSTOMER" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Grid.Row="1" Background="{DynamicResource BgPage}" CornerRadius="12" Padding="14,12" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="30" Height="30" CornerRadius="15" Background="{DynamicResource IconBgIndigo}">
                                <TextBlock Text="👤" Foreground="{DynamicResource IconFgIndigo}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="CustomerNameText" Text="Walk-in Customer" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                <TextBlock x:Name="CustomerPhoneText" Text="No Phone Attached" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Numpad grid -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="⌨  QUICK NUMPAD" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold"/>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="42"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 1 -->
                            <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="2" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="0" Grid.Column="4" Content="3" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>

                            <!-- Row 2 -->
                            <Button Grid.Row="2" Grid.Column="0" Content="4" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="5" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="2" Grid.Column="4" Content="6" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>

                            <!-- Row 3 -->
                            <Button Grid.Row="4" Grid.Column="0" Content="7" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="4" Grid.Column="2" Content="8" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="4" Grid.Column="4" Content="9" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>

                            <!-- Row 4 -->
                            <Button Grid.Row="6" Grid.Column="0" Content="C" Style="{DynamicResource NumPadBtnStyle}" Foreground="{DynamicResource AccentDanger}" Click="NumPad_Click"/>
                            <Button Grid.Row="6" Grid.Column="2" Content="0" Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>
                            <Button Grid.Row="6" Grid.Column="4" Content="." Style="{DynamicResource NumPadBtnStyle}" Click="NumPad_Click"/>

                            <!-- Exact Amount Button -->
                            <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5" Content="EXACT AMOUNT" Click="ExactAmount_Click"
                                    Background="{DynamicResource AccentSuccess}" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Black">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <!-- Shared dialog resources -->
    <Window.Resources>
        <!-- Numpad Button style -->
        <Style x:Key="NumPadBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimary}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Method selection Button style -->
        <Style x:Key="MethodBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bump Button style -->
        <Style x:Key="BumpBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
</Window>
