<Window x:Class="DesktopPOS.Pages.InvoiceReprintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reprint Invoice" Height="650" Width="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="700" Height="600" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="32,28">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="50" ShadowDepth="8"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Reprint Invoice" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <DatePicker x:Name="DatePickerField" Grid.Column="0" Margin="0,0,10,0"
                        FontSize="14" Padding="5" VerticalAlignment="Center" SelectedDateChanged="DatePickerField_SelectedDateChanged"/>
            
            <Button Grid.Column="1" Content="Clear Date" Width="100" Padding="8" Margin="0,0,10,0"
                    Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderPrimary}" Cursor="Hand"
                    Click="ClearDate_Click"/>

            <Button Grid.Column="2" Content="Refresh" Width="100" Padding="8"
                    Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand" Click="Refresh_Click"/>
        </Grid>

        <TextBlock x:Name="LoadingText" Text="Loading invoices..." Grid.Row="2" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <ListBox x:Name="InvoicesGrid" Grid.Row="2" Background="Transparent" BorderThickness="0"
                 Visibility="Collapsed" SelectionChanged="InvoicesGrid_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="CardBorder" Background="{DynamicResource BgCard}" CornerRadius="12" Margin="0,0,0,10" Padding="15"
                                        BorderBrush="Transparent" BorderThickness="2" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon -->
                                        <Border Width="46" Height="46" CornerRadius="23" Background="{DynamicResource IconBgIndigo}" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <TextBlock Text="🧾" Foreground="{DynamicResource IconFgIndigo}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding invoice_no}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding customer_name}" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Text=" • " FontSize="13" Foreground="{DynamicResource TextMuted}"/>
                                                <TextBlock Text="{Binding created_at}" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- Total -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="Total" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding grand_total, StringFormat='LKR \{0:N2\}'}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource BgInput}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource BgInput}"/>
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Close" Width="100" Padding="10" Margin="0,0,10,0"
                    Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderPrimary}" Cursor="Hand"
                    Click="Close_Click"/>
            <Button x:Name="PrintBtn" Content="Reprint Selected" Width="150" Padding="10"
                    Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand" Click="Print_Click" IsEnabled="False"/>
        </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
