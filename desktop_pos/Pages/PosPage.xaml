<Page x:Class="DesktopPOS.Pages.PosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:DesktopPOS.Controls"
      Title="POS" Background="{DynamicResource BgPage}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- === GLOBAL TOP BAR === -->
        <controls:TopNavBar Grid.Row="0"/>

        <!-- === POS CONTENT === -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left sidebar for categories -->
                <ColumnDefinition Width="160"/>
                <!-- Product area -->
                <ColumnDefinition Width="*"/>
                <!-- Right cart panel -->
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  LEFT SIDEBAR — Collections & Categories                   -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource BgPage}" Padding="0">
            <DockPanel>
                <!-- Sidebar Header -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource BgPanel}" Padding="14,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderPrimary}">
                    <DockPanel>
                        <TextBlock Text="COLLECTIONS" Foreground="{DynamicResource AccentSecondary}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Search groups -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource BgPanel}" Padding="12,8">
                    <Border Background="{DynamicResource BgCard}" CornerRadius="6" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Search groups..." Foreground="{DynamicResource BorderLight}" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- All Items (Active) -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource BgInput}" Margin="8,8,8,2" CornerRadius="8"
                        Padding="12,9" Cursor="Hand" MouseLeftButtonUp="AllItems_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊟" Foreground="{DynamicResource AccentSecondary}" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="All Items" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Category Groups -->
                <StackPanel DockPanel.Dock="Top" Margin="8,10,8,0">
                    <TextBlock Text="RECIPE TYPES" Foreground="{DynamicResource BorderLight}" FontSize="9" FontWeight="Bold" Margin="4,0,0,6"/>
                    <Border x:Name="CatStandard" Background="Transparent" CornerRadius="8" Padding="12,8" Cursor="Hand" Margin="0,1" MouseLeftButtonUp="CatStandard_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Standard" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="CatAlaCarte" Background="Transparent" CornerRadius="8" Padding="12,8" Cursor="Hand" Margin="0,1" MouseLeftButtonUp="CatAlaCarte_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentWarning}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="A La Carte" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="CatRecipe" Background="Transparent" CornerRadius="8" Padding="12,8" Cursor="Hand" Margin="0,1" MouseLeftButtonUp="CatRecipe_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#A855F7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Recipe" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Quick Filter badge at bottom -->
                <DockPanel DockPanel.Dock="Bottom" Margin="12,0,12,12" VerticalAlignment="Bottom">
                    <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="10,6">
                        <DockPanel>
                            <TextBlock Text="QUICK FILTER" Foreground="{DynamicResource BorderLight}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right" Background="{DynamicResource BgInput}" CornerRadius="10" Padding="6,2">
                                <TextBlock Text="0" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                    </Border>
                </DockPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  CENTER — Search Bar + Product Grid                        -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{DynamicResource BgPage}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top toolbar: search & toggles -->
            <Border Grid.Row="0" Background="{DynamicResource BgPanel}" Padding="16,10">
                <DockPanel>
                    <!-- Settings/Toggle Images -->
                    <Button DockPanel.Dock="Right" Margin="10,0,0,0" Padding="12,0" Height="38"
                            Background="{DynamicResource BgCard}" Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                            Cursor="Hand" Click="RefreshCache_Click" ToolTip="Force refresh products from server">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button DockPanel.Dock="Right" Margin="10,0,0,0" Padding="12,0" Height="38"
                            Background="{DynamicResource BgCard}" Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                            Cursor="Hand" Click="ToggleImages_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ToggleImagesIcon" Text="🖼️" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ToggleImagesText" Text="Hide Images" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Search Bar -->
                    <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="12,0" Height="38">
                        <DockPanel>
                            <TextBlock Text="🔍" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                            <TextBox x:Name="SearchBox" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                     FontSize="13" VerticalAlignment="Center" CaretBrush="{DynamicResource TextPrimary}"
                                     TextChanged="SearchBox_TextChanged">
                                <TextBox.Resources>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Products Grid -->
            <Grid Grid.Row="1">
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⌛  Loading products..." Foreground="{DynamicResource TextSecondary}" FontSize="15"/>
                </StackPanel>
                <StackPanel x:Name="EmptyPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="No products found" Foreground="{DynamicResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
                <ScrollViewer x:Name="ProductScroller" VerticalScrollBarVisibility="Auto" Visibility="Collapsed" Padding="10,10,10,10">
                    <WrapPanel x:Name="ProductsPanel" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  RIGHT — Cart Panel                                        -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Restaurant / Location Bar -->
                <Border Grid.Row="0" Background="{DynamicResource BgPanel}" Padding="14,10">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Background="{DynamicResource AccentWarning}" CornerRadius="5" Padding="6,3" Cursor="Hand">
                            <TextBlock Text="HELD (0)" Foreground="{DynamicResource TextInverted}" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="🏪  BizzFlow POS" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Customer + Table + Mode Row -->
                <Border Grid.Row="1" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BgInput}" BorderThickness="0,1,0,1" Padding="14,10">
                    <StackPanel>
                        <Border Background="Transparent" Cursor="Hand" MouseLeftButtonUp="SelectCustomer_Click" Margin="0,0,0,6">
                            <DockPanel>
                                <TextBlock Text="👤" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="CustomerDisplay" Text="Walk-in Customer" Foreground="{DynamicResource AccentSecondary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="Change ›" Foreground="{DynamicResource TextMuted}" FontSize="10" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <DockPanel>
                            <Border DockPanel.Dock="Left" Background="{DynamicResource BgCardElevated}" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock x:Name="OrderTypeBadge" Text="RETAIL" Foreground="{DynamicResource AccentSuccess}" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="TableBadge" Text="" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right" Background="{DynamicResource BgCard}" CornerRadius="5" Padding="8,3" Cursor="Hand" HorizontalAlignment="Right">
                                <TextBlock Text="CHANGE" Foreground="{DynamicResource AccentSecondary}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Cart Items -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Empty state -->
                        <StackPanel x:Name="EmptyCartPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,60,0,0">
                            <TextBlock Text="🛒" FontSize="50" HorizontalAlignment="Center" Foreground="{DynamicResource BgInput}"/>
                            <TextBlock Text="Order Started..." Foreground="{DynamicResource TextMuted}" FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,12,0,4"/>
                            <TextBlock x:Name="OrderModeHint" Text="Mode: RETAIL" Foreground="{DynamicResource AccentSecondary}" FontSize="13"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Search for products on the Menu tab to add them to this list."
                                       Foreground="{DynamicResource BorderLight}" FontSize="12" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="20,8,20,0"/>
                        </StackPanel>

                        <!-- Cart Items List -->
                        <ItemsControl x:Name="CartItemsControl" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BgInput}" BorderThickness="0,0,0,1" Padding="14,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Margin="0,0,0,6">
                                                <DockPanel Margin="0,0,0,2">
                                                    <Border DockPanel.Dock="Right" Background="Transparent" Cursor="Hand"
                                                            Tag="{Binding}" MouseLeftButtonUp="RemoveItem_Click">
                                                        <TextBlock Text="✕" Foreground="{DynamicResource AccentDanger}" FontSize="11"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="13"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding DiscountDisplay}" Foreground="{DynamicResource AccentWarning}" FontSize="11" 
                                                           Visibility="{Binding DiscountVisibility}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <DockPanel Grid.Row="1">
                                                <TextBlock Text="{Binding LineTotalDisplay}" DockPanel.Dock="Right"
                                                           Foreground="{DynamicResource AccentSuccess}" FontSize="14" FontWeight="Bold"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="26" Height="26" CornerRadius="6" Background="{DynamicResource BgInput}"
                                                            Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="DecreaseQty_Click">
                                                        <TextBlock Text="−" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding QuantityDisplay}" Foreground="{DynamicResource TextPrimary}" FontSize="13"
                                                               FontWeight="Bold" Width="34" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <Border Width="26" Height="26" CornerRadius="6" Background="{DynamicResource BgInput}"
                                                            Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="IncreaseQty_Click">
                                                        <TextBlock Text="+" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding PriceDisplay}" Foreground="{DynamicResource TextMuted}"
                                                               FontSize="11" VerticalAlignment="Center" Margin="8,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Order Totals + Actions -->
                <Border Grid.Row="3" Background="{DynamicResource BgPanel}" Padding="14,12">
                    <StackPanel>
                        <!-- Subtotal -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Subtotal :" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="SubtotalText" Text="LKR 0" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="13" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>

                        <!-- Apply Discount -->
                        <!-- Apply Discount -->
                        <Border x:Name="ApplyDiscountBtn" Background="{DynamicResource BgCard}" CornerRadius="8" Padding="12,9" Margin="0,0,0,8" Cursor="Hand" PreviewMouseLeftButtonDown="ApplyDiscount_Click" ToolTip="Apply Bill Discount (F8)">
                            <DockPanel>
                                <TextBlock Text="🏷" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                                <Border DockPanel.Dock="Right" Background="{DynamicResource BgInput}" CornerRadius="6" Width="26" Height="26">
                                    <TextBlock Text="✎" Foreground="{DynamicResource AccentSecondary}" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="DiscountLabel" Text="APPLY DISCOUNT (F8)" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- Tax breakdown -->
                        <ItemsControl x:Name="TaxesItemsControl" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding code, StringFormat='{}{0} '}" Foreground="{DynamicResource BorderLight}" FontSize="10"/>
                                        <TextBlock Text="{Binding CalculatedAmount, StringFormat='LKR {0:N2}'}" Foreground="{DynamicResource BorderLight}" FontSize="10"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Total -->
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="TOTAL" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                            <TextBlock x:Name="GrandTotalText" Text="LKR 0.00" Foreground="{DynamicResource AccentSuccess}"
                                       FontSize="22" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>

                        <!-- Bottom action buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" Height="50" Margin="0,0,5,0"
                                    Background="{DynamicResource BgCard}" Foreground="{DynamicResource TextSecondary}" BorderThickness="1"
                                    BorderBrush="{DynamicResource BgInput}" FontSize="12" FontWeight="SemiBold"
                                    Click="HoldPrint_Click" ToolTip="Hold Order (F7)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏸" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="HOLD" Foreground="{DynamicResource TextSecondary}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button Grid.Column="1" Height="50" Margin="5,0,0,0"
                                    Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0"
                                    FontSize="15" FontWeight="Bold" Click="Checkout_Click" ToolTip="Checkout (F9)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#4F46E5" BlurRadius="16" Opacity="0.5" ShadowDepth="0"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="➔" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock Text="CHECKOUT" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Grid>
</Page>







