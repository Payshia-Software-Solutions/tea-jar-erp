<Window x:Class="DesktopPOS.Pages.CardDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Details" Height="420" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="400" Height="400" Background="{DynamicResource BgCardElevated}" CornerRadius="16" Padding="24" BorderThickness="1" BorderBrush="{DynamicResource BorderPrimary}">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="30" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CARD DETAILS" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Black"/>
                    <Button Grid.Column="1" Content="✕" Width="26" Height="26"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="10" Click="Cancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Card Types -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="CARD GATEWAY / TYPE" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                    <UniformGrid Columns="4">
                        <Button x:Name="VisaBtn" Content="Visa" Height="36" Margin="0,0,4,0" Click="CardTypeBtn_Click" Style="{DynamicResource CardTypeBtnStyle}"/>
                        <Button x:Name="MasterBtn" Content="Master" Height="36" Margin="2,0,2,0" Click="CardTypeBtn_Click" Style="{DynamicResource CardTypeBtnStyle}"/>
                        <Button x:Name="AmexBtn" Content="Amex" Height="36" Margin="2,0,2,0" Click="CardTypeBtn_Click" Style="{DynamicResource CardTypeBtnStyle}"/>
                        <Button x:Name="OtherBtn" Content="Other" Height="36" Margin="4,0,0,0" Click="CardTypeBtn_Click" Style="{DynamicResource CardTypeBtnStyle}"/>
                    </UniformGrid>
                </StackPanel>

                <!-- Textboxes -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="CARD NUMBER (LAST 4 DIGITS)" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BgInput}" CornerRadius="8" Height="44" Margin="0,0,0,16" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                        <TextBox x:Name="CardLast4Box" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" FontSize="15" Padding="12,0" VerticalContentAlignment="Center" MaxLength="4" CaretBrush="{DynamicResource TextPrimary}" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                    </Border>

                    <TextBlock Text="TERMINAL AUTH CODE" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BgInput}" CornerRadius="8" Height="44" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                        <TextBox x:Name="CardAuthBox" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" FontSize="15" Padding="12,0" VerticalContentAlignment="Center" CaretBrush="{DynamicResource TextPrimary}"/>
                    </Border>
                    
                    <TextBlock x:Name="ErrorText" Foreground="{DynamicResource AccentDanger}" FontSize="11" FontWeight="Bold" Margin="0,10,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Action Button -->
                <Button Grid.Row="3" Content="Confirm Card details" Height="42" Click="Confirm_Click"
                        Background="{DynamicResource AccentPrimary}" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="CardTypeBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
