<Window x:Class="DesktopPOS.Pages.StewardSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Steward" Height="650" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="600" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="36,32">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="60" ShadowDepth="10"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,30">
                    <Button DockPanel.Dock="Right" Content="✕" Width="32" Height="32"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="14" Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Select Steward" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Assign a steward to this order" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- None/Skip Steward -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="14" Margin="0,0,0,20"
                        Cursor="Hand" MouseLeftButtonUp="SkipSteward_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource BgInput}">
                            <TextBlock Text="👤" Foreground="{DynamicResource AccentSecondary}" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="None / Skip Steward" Foreground="White"
                                   FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <Border Grid.Column="2" Background="{DynamicResource BgInput}" CornerRadius="6" VerticalAlignment="Center" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="0" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Stewards Grid -->
                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,0,-12,0" Padding="0,0,12,0">
                    <WrapPanel x:Name="StewardsPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ScrollViewer>

                <!-- Loading text -->
                <TextBlock x:Name="LoadingText" Text="Loading stewards..." Foreground="{DynamicResource TextMuted}"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
