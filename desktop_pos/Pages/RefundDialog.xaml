<Window x:Class="DesktopPOS.Pages.RefundDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Financial Refund" Height="620" Width="850"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BgBase}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Pending Refunds List -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="PENDING REFUNDS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
            
            <ListBox x:Name="PendingRefundsList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch"
                     SelectionChanged="PendingRefundsList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{DynamicResource BgCard}" CornerRadius="10" Margin="0,0,0,8" Padding="12"
                                            BorderThickness="1" BorderBrush="{DynamicResource BorderPrimary}" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding return_no}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Grid.Row="1" Text="{Binding customer_name}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            <Grid Grid.Row="2" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding return_date}" FontSize="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding total_amount, StringFormat='LKR \{0:N2\}'}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Loading indicator for list -->
            <TextBlock x:Name="ListStatusText" Grid.Row="1" Text="Loading returns..." Foreground="{DynamicResource TextMuted}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
        </Grid>

        <!-- Vertical Divider -->
        <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderPrimary}" Margin="5,0"/>

        <!-- Right Pane: Details & Form -->
        <Grid Grid.Column="2" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0" FontSize="16" Padding="8" 
                         Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1" 
                         Margin="0,0,10,0" KeyDown="SearchBox_KeyDown" />
                <TextBlock IsHitTestVisible="False" Text="Scan or type Return Number..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" Foreground="{DynamicResource TextMuted}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="1" Content="Lookup" Width="90" Padding="8" 
                        Background="{DynamicResource AccentPrimary}" Foreground="White" 
                        BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand"
                        Click="LookupButton_Click"/>
            </Grid>

            <!-- Status Messages -->
            <TextBlock x:Name="StatusMessage" Grid.Row="1" Text="Please select a pending return from the left or search manually." Foreground="{DynamicResource TextMuted}" FontSize="15" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="450" TextAlignment="Center"/>

            <!-- Details Container (hidden until return document loaded) -->
            <Grid x:Name="DetailsContainer" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Document Info Summary -->
                <Border Grid.Row="0" Background="{DynamicResource BgCard}" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ReturnNoText" Text="Return#: " FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="CustomerNameText" Text="Customer: " FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="InvoiceNoText" Text="Orig. Invoice: " FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="RefundStatusText" Text="Status: Unpaid" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AccentWarning}"/>
                            <TextBlock x:Name="ReasonText" Text="Reason: " FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Returned Items (Read-only view) -->
                <ListBox x:Name="ItemsList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{DynamicResource BgCard}" CornerRadius="10" Margin="0,0,0,6" Padding="10"
                                                BorderThickness="1" BorderBrush="{DynamicResource BorderPrimary}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding description}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding unit_price, StringFormat='LKR \{0:N2\}'}" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding quantity, StringFormat='\{0\} Unit(s)'}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding line_total, StringFormat='LKR \{0:N2\}'}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Payment Details Input Form -->
                <Border Grid.Row="2" Background="{DynamicResource BgCard}" CornerRadius="12" Padding="15" Margin="0,12,0,0" x:Name="PaymentForm">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left: Method selector -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Refund Payment Method" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="MethodComboBox" Height="36" FontSize="13" Background="{DynamicResource BgInput}" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1" SelectionChanged="MethodComboBox_SelectionChanged">
                                <ComboBoxItem Content="Cash" IsSelected="True"/>
                                <ComboBoxItem Content="Bank Transfer"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Right: Reference Info -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock x:Name="RefLabel" Text="Reference No (Optional)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox x:Name="RefTextBox" Height="36" FontSize="13" Padding="8,6" Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Totals & Actions -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TotalRefundText" Text="Refund Amount: LKR 0.00" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Close" Width="100" Padding="8" Margin="0,0,10,0"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}" 
                            BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                            FontSize="14" Cursor="Hand" Click="CloseButton_Click"/>
                    
                    <Button x:Name="ProcessButton" Content="Issue Refund" Width="140" Padding="8"
                            Background="{DynamicResource AccentSuccess}" Foreground="White" 
                            BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand"
                            Click="ProcessButton_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
