<Page x:Class="DesktopPOS.Pages.LocationSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Select Location" Background="{DynamicResource BgPage}">

    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="450" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="36,32">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="60" ShadowDepth="10"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Select Branch" Foreground="{DynamicResource TextPrimary}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="You have access to multiple locations. Please select the branch you are operating." Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,24"/>

                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LocationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgCard}" CornerRadius="12" Margin="0,0,0,10"
                                        Padding="20,16" Cursor="Hand" MouseLeftButtonUp="Location_Click" Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BgInput}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="False">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <TextBlock Text="🏪" Foreground="{DynamicResource AccentSecondary}" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding name}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="→" Foreground="{DynamicResource AccentSecondary}" FontSize="20" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Page>
