<Page x:Class="DesktopPOS.Pages.CustomerSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Select Customer" Background="{DynamicResource BgPage}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="40,40,40,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕ Cancel" Width="100" Height="36"
                        Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                        FontSize="13" Click="Cancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <StackPanel>
                    <TextBlock Text="Select Customer" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Step 1 of 3 — Choose who is placing the order" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Search Bar + Walk-in Button -->
        <Grid Grid.Row="1" Margin="40,24,40,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#121828" CornerRadius="10" Margin="0,0,16,0" Padding="16,0">
                <DockPanel>
                    <TextBlock Text="🔍" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0" DockPanel.Dock="Left"/>
                    <TextBox x:Name="SearchBox" Background="Transparent" Foreground="White" BorderThickness="0"
                             FontSize="15" VerticalAlignment="Center" Padding="0,12"
                             CaretBrush="White" TextChanged="SearchBox_TextChanged"
                             Text="">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </DockPanel>
            </Border>

            <Button Grid.Column="1" Content="👤  Walk-in Customer" Height="48"
                    Background="{DynamicResource AccentSuccess}" Foreground="White" BorderThickness="0"
                    FontSize="14" FontWeight="Bold" Click="WalkIn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Customer List -->
        <Border Grid.Row="2" Margin="40,0,40,0" Background="#121828" CornerRadius="12">
            <Grid>
                <!-- Loading Indicator -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading customers..." Foreground="{DynamicResource TextSecondary}" FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Empty Message -->
                <StackPanel x:Name="EmptyPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="👥" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="No customers found" Foreground="{DynamicResource TextSecondary}" FontSize="16" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Customer List -->
                <ListView x:Name="CustomerListView" Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          SelectionChanged="CustomerListView_SelectionChanged"
                          Padding="8" Visibility="Collapsed">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="ItemBorder" Background="{DynamicResource BgInput}" CornerRadius="10" Padding="16,12" Margin="4,3">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#273548"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#1d3461"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#1E3A5F">
                                    <TextBlock x:Name="AvatarText" Text="{Binding Initials}" Foreground="{DynamicResource AccentSecondary}"
                                               FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- Name + Phone -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock Text="{Binding name}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding phone}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <!-- Arrow -->
                                <TextBlock Grid.Column="2" Text="›" Foreground="{DynamicResource AccentSecondary}" FontSize="22" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Step Indicator -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,30">
            <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentPrimary}" Margin="4,0"/>
            <Ellipse Width="10" Height="10" Fill="{DynamicResource BorderLight}" Margin="4,0"/>
            <Ellipse Width="10" Height="10" Fill="{DynamicResource BorderLight}" Margin="4,0"/>
        </StackPanel>
    </Grid>
</Page>







