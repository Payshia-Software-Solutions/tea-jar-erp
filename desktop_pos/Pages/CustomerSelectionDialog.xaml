<Window x:Class="DesktopPOS.Pages.CustomerSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Customer" Height="620" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="460" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="32,28">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="50" ShadowDepth="8"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,20">
                    <Button DockPanel.Dock="Right" Content="✕" Width="30" Height="30"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="12" Click="Close_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="Select Customer" Foreground="{DynamicResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Search or select billing customer" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Search box -->
                <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="12,0" Height="40" Margin="0,0,0,16" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock Text="🔍" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                        <TextBox x:Name="SearchBox" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                 FontSize="13" VerticalAlignment="Center" CaretBrush="{DynamicResource TextPrimary}"
                                 TextChanged="SearchBox_TextChanged"/>
                    </DockPanel>
                </Border>

                <!-- Walk-in Customer Button -->
                <Button Content="👤  Walk-in Customer" Height="44" Margin="0,0,0,16" Click="WalkIn_Click"
                        Background="{DynamicResource AccentSecondary}" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Customer list -->
                <Grid Height="300">
                    <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⌛ Loading customers..." Foreground="{DynamicResource TextMuted}" FontSize="14"/>
                    </StackPanel>

                    <StackPanel x:Name="EmptyPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="No customers found." Foreground="{DynamicResource TextMuted}" FontSize="14"/>
                    </StackPanel>

                    <ListBox x:Name="CustomerListView" Background="Transparent" BorderThickness="0"
                             SelectionChanged="CustomerListView_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="10" Padding="12,10" BorderBrush="Transparent" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BgInput}"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BorderPrimary}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentPrimary}"/>
                                                    <Setter TargetName="ItemBorder" Property="TextElement.Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding name}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding phone}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Select ›" Foreground="{DynamicResource AccentSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
