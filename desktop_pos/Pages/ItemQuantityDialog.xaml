<Window x:Class="DesktopPOS.Pages.ItemQuantityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Item" Height="650" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="860" Height="600" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="16">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="60" ShadowDepth="10"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

            <!-- Close button top right -->
            <Button Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Content="✕" Width="36" Height="36" Margin="0,16,16,0"
                    Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                    FontSize="14" Click="Close_Click" Panel.ZIndex="10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- LEFT: Product Info -->
            <Grid Grid.Column="0" Margin="16">
                <StackPanel VerticalAlignment="Top">
                    <!-- Type badges -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border x:Name="ServiceBadge" Background="#3B0A6E" CornerRadius="6" Padding="8,4" Margin="0,0,8,0" Visibility="Collapsed">
                            <TextBlock Text="SERVICE" Foreground="#C084FC" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Border x:Name="TypeBadge" Background="#2A1B08" CornerRadius="6" Padding="8,4">
                            <TextBlock x:Name="TypeBadgeText" Text="A LA CARTE" Foreground="{DynamicResource AccentWarning}" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="ProductName" Text="Product Name" Foreground="{DynamicResource TextPrimary}"
                               FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock x:Name="ProductSku" Text="SKU-000000" Foreground="{DynamicResource BorderLight}" FontSize="13"/>
                </StackPanel>

                <!-- Line Discount (bottom of left panel) -->
                <Border VerticalAlignment="Bottom" Background="{DynamicResource BgCard}" CornerRadius="10" Padding="14,12">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Background="{DynamicResource BgInput}" CornerRadius="6" Padding="10,5" Cursor="Hand"
                                PreviewMouseLeftButtonDown="AddDiscount_Click">
                            <TextBlock Text="ADD" Foreground="{DynamicResource AccentSecondary}" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BgInput}" CornerRadius="6" Width="32" Height="32" Margin="0,0,10,0">
                                <TextBlock Text="🏷" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="LINE DISCOUNT" Foreground="{DynamicResource TextMuted}" FontSize="9" FontWeight="Bold"/>
                                <TextBlock x:Name="DiscountStatus" Text="None applied" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource BgInput}" Width="1"/>

            <!-- RIGHT: Numpad -->
            <Grid Grid.Column="2" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- QUANTITY label -->
                <TextBlock Grid.Row="0" Text="QUANTITY" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- Display -->
                <Border Grid.Row="1" Background="{DynamicResource BgCard}" CornerRadius="10" Padding="16,14" Margin="0,0,0,16">
                    <TextBlock x:Name="QtyDisplay" Text="1" Foreground="{DynamicResource TextPrimary}" FontSize="32"
                               FontWeight="Bold" HorizontalAlignment="Right"/>
                </Border>

                <!-- Numpad grid -->
                <Grid Grid.Row="2" Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1: 1 2 3 -->
                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="1">
                        <TextBlock Text="1" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="2">
                        <TextBlock Text="2" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="3">
                        <TextBlock Text="3" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>

                    <!-- Row 2: 4 5 6 -->
                    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="4">
                        <TextBlock Text="4" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="5">
                        <TextBlock Text="5" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="6">
                        <TextBlock Text="6" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>

                    <!-- Row 3: 7 8 9 -->
                    <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="7">
                        <TextBlock Text="7" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="8">
                        <TextBlock Text="8" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="9">
                        <TextBlock Text="9" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>

                    <!-- Row 4: . 0 DEL -->
                    <Border Grid.Row="3" Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag=".">
                        <TextBlock Text="." Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Num_Click" Tag="0">
                        <TextBlock Text="0" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="2" Background="{DynamicResource IconBgRed}" CornerRadius="10" Margin="4" Cursor="Hand" PreviewMouseLeftButtonDown="Del_Click">
                        <TextBlock Text="DEL" Foreground="{DynamicResource AccentDanger}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Border>
                </Grid>

                <!-- Add to Cart Button -->
                <Button Grid.Row="3" Height="56" Margin="0,16,0,0"
                        Background="#4F8EF7" Foreground="White" BorderThickness="0"
                        FontSize="15" FontWeight="Bold" Click="AddToCart_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                <Border.Effect>
                                    <DropShadowEffect Color="#4F8EF7" BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒  " FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="ADD TO SHOPPING CART" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
            <!-- Close overall Grid inside Border -->
            </Grid>
        </Border>
    </Grid>
</Window>







