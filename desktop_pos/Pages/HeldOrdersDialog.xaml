<Window x:Class="DesktopPOS.Pages.HeldOrdersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recall Held Order" Height="600" Width="700"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Background="{DynamicResource BgBase}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Held Orders" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

        <ListBox x:Name="OrdersList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,12"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="12" Background="{DynamicResource BgCard}" BorderThickness="2" Padding="15">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource BgInput}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                        <!-- slight tint to show it's selected -->
                                        <Setter Property="Background" Value="#1A4F46E5"/> 
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Icon / ID -->
                            <Border Width="50" Height="50" CornerRadius="10" Background="{DynamicResource BgInput}" Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="{Binding id, StringFormat=#{0}}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Details -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding customer_name}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="16"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding created_at}" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                    <TextBlock Text="  •  " Foreground="{DynamicResource BgInput}" FontSize="13"/>
                                    <TextBlock Text="{Binding order_type}" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                    <TextBlock Text="  •  " Foreground="{DynamicResource BgInput}" FontSize="13"/>
                                    <TextBlock Text="Table " Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                    <TextBlock Text="{Binding table_id}" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Amount -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Amount" Foreground="{DynamicResource TextSecondary}" FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding grand_total, StringFormat=LKR \{0:N2\}}" Foreground="{DynamicResource AccentPrimary}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Print Full KOT" Width="120" Height="40" Margin="0,0,10,0"
                    Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}"
                    Click="PrintKot_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Width="100" Height="40" Margin="0,0,10,0"
                    Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}"
                    Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Resume Order" Width="140" Height="40"
                    Background="{DynamicResource AccentPrimary}" Foreground="White" FontWeight="Bold"
                    Click="Resume_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed" CornerRadius="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading Held Orders..." Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Please wait..." Foreground="{DynamicResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
