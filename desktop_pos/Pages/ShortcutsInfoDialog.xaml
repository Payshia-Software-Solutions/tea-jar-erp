<Window x:Class="DesktopPOS.Pages.ShortcutsInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Shortcuts" Height="580" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Background="Transparent">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="460" Background="{DynamicResource BgCardElevated}" CornerRadius="20" Padding="32,28">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" Opacity="0.15" BlurRadius="50" ShadowDepth="8"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,24">
                    <Button DockPanel.Dock="Right" Content="✕" Width="30" Height="30"
                            Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                            FontSize="12" Click="Close_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="Keyboard Shortcuts" Foreground="{DynamicResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="System-wide rapid navigation shortcuts" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Shortcut Items -->
                <StackPanel>
                    <Border Background="{DynamicResource BgInput}" Height="1" Margin="0,0,0,16"/>

                    <!-- Global / App Wide -->
                    <TextBlock Text="GLOBAL / NAVIGATION" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="F11" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Toggle Full Screen view" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="ESC" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Close any open modal or dialog window" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <!-- POS Shortcuts -->
                    <Border Background="{DynamicResource BgInput}" Height="1" Margin="0,12,0,16"/>
                    <TextBlock Text="POS SALES PAGE" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="F7" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Hold / Save current active order" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="F8" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Open Bill Discount input popup" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="F9" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Proceed to Checkout and payment" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="D or F4" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Open Item Line Discount dialog (inside Quantity Popup)" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="ENTER" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Confirm &amp; Add item to cart (inside Popups)" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <!-- Selection Popups -->
                    <Border Background="{DynamicResource BgInput}" Height="1" Margin="0,12,0,16"/>
                    <TextBlock Text="ORDER / TABLE / STEWARD SELECTION" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="1 - 3" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Select Order Type (Dine In, Take Away, Retail)" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="0" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Skip Table selection / Skip Steward selection" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource BgInput}" CornerRadius="6" Padding="8,4" BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1">
                            <TextBlock Text="1 - 9" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Select active Table or Steward in numeric order" Foreground="{DynamicResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
