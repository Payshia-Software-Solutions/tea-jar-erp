<UserControl x:Class="DesktopPOS.Controls.TopNavBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource BgPanel}" Padding="32,18,32,18"
            BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="GreetingText" Text="Good Morning! 👋" 
                           Foreground="{DynamicResource TextPrimary}" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="DateText" Text="" 
                           Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,2,0,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Location -->
                <StackPanel Margin="0,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Location" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="LocationText" Text="Main Branch" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </StackPanel>

                <!-- User Profile -->
                <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource AccentPrimary}" Margin="0,0,12,0">
                    <TextBlock x:Name="UserInitial" Text="U" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText" Text="Cashier" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentSuccess}" Margin="0,0,5,0"/>
                        <TextBlock Text="Online" Foreground="{DynamicResource AccentSuccess}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Home Button -->
                <Button Width="36" Height="36" Margin="0,0,12,0"
                        Background="{DynamicResource BgCard}" BorderThickness="0"
                        Click="Home_Click" Cursor="Hand" ToolTip="Home (Dashboard)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" 
                                          Fill="{DynamicResource TextPrimary}"/>
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Keyboard Shortcuts Info -->
                <Button Width="36" Height="36" Margin="0,0,12,0"
                        Background="{DynamicResource BgCard}" BorderThickness="0"
                        Click="ShortcutsInfo_Click" Cursor="Hand" ToolTip="System Keyboard Shortcuts">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M20,5H4C2.89,5 2,5.89 2,7V17C2,18.11 2.89,19 4,19H20C21.11,19 22,18.11 22,17V7C22,5.89 21.11,5 20,5M20,17H4V7H20V17M11,8H13V10H11V8M11,11H13V13H11V11M8,8H10V10H8V8M8,11H10V13H8V11M5,8H7V10H5V8M5,11H7V13H5V11M16,11H19V13H16V11M14,8H19V10H14V8M14,11H15V13H14V11M8,14H16V16H8V14Z" 
                                          Fill="{DynamicResource TextPrimary}"/>
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Theme Toggle -->
                <Button Width="36" Height="36" Margin="0,0,12,0"
                        Background="{DynamicResource BgCard}" BorderThickness="0"
                        Click="ToggleTheme_Click" Cursor="Hand" ToolTip="Toggle Theme">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4V20A8,8 0 0,1 4,12A8,8 0 0,1 12,4Z" 
                                          Fill="{DynamicResource TextPrimary}"/>
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings Button -->
                <Button Width="36" Height="36" Margin="0,0,12,0"
                        Background="{DynamicResource BgCard}" BorderThickness="0"
                        Click="Settings_Click" Cursor="Hand" ToolTip="Settings">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M19.14,12.94C19.18,12.63 19.2,12.32 19.2,12C19.2,11.68 19.18,11.37 19.14,11.06L21.16,9.48C21.34,9.33 21.39,9.08 21.28,8.87L19.36,5.55C19.25,5.34 19,5.26 18.79,5.34L16.42,6.3C15.93,5.92 15.39,5.61 14.8,5.37L14.44,2.84C14.4,2.62 14.21,2.46 13.99,2.46H10.01C9.79,2.46 9.6,2.62 9.56,2.84L9.2,5.37C8.61,5.61 8.07,5.92 7.58,6.3L5.21,5.34C5,5.26 4.75,5.34 4.64,5.55L2.72,8.87C2.61,9.08 2.66,9.33 2.84,9.48L4.86,11.06C4.82,11.37 4.8,11.68 4.8,12C4.8,12.32 4.82,12.63 4.86,12.94L2.84,14.52C2.66,14.67 2.61,14.92 2.72,15.13L4.64,18.45C4.75,18.66 5,18.74 5.21,18.66L7.58,17.7C8.07,18.08 8.61,18.39 9.2,18.63L9.56,21.16C9.6,21.38 9.79,21.54 10.01,21.54H13.99C14.21,21.54 14.4,21.38 14.44,21.16L14.8,18.63C15.39,18.39 15.93,18.08 16.42,17.7L18.79,18.66C19,18.74 19.25,18.66 19.36,18.45L21.28,15.13C21.39,14.92 21.34,14.67 21.16,14.52L19.14,12.94M12,15.6C10.01,15.6 8.4,13.99 8.4,12C8.4,10.01 10.01,8.4 12,8.4C13.99,8.4 15.6,10.01 15.6,12C15.6,13.99 13.99,15.6 12,15.6Z" 
                                          Fill="{DynamicResource TextPrimary}"/>
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Fullscreen Toggle Button -->
                <Button Width="36" Height="36" Margin="0,0,12,0"
                        Background="{DynamicResource BgCard}" BorderThickness="0"
                        Click="ToggleFullscreen_Click" Cursor="Hand" ToolTip="Toggle Full Screen">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M4,4H10V6H6V10H4V4M20,4V10H18V6H14V4H20M4,20V14H6V18H10V20H4M20,20H14V18H18V14H20V20Z" 
                                          Fill="{DynamicResource TextPrimary}"/>
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Close App Button -->
                <Button Width="36" Height="36" Margin="0,0,16,0"
                        Background="{DynamicResource BgCard}" BorderThickness="0"
                        Click="CloseApp_Click" Cursor="Hand" ToolTip="Exit Application">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                          Fill="{DynamicResource AccentDanger}"/>
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
